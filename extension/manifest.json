{
  "manifest_version": 3,
  "name": "Passwordn",
  "short_name": "Passwordn",
  "version": "1.0.0",
  "description": "Passwordn — a secure vault for passwords and payment methods with autofill and new-login capture.",
  "author": "Passwordn",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Passwordn",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": ["storage", "activeTab", "scripting", "tabs", "notifications"],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "autofill-login": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac":     "Command+Shift+L"
      },
      "description": "Autofill the matching saved login"
    }
  },
  "minimum_chrome_version": "109"
}
